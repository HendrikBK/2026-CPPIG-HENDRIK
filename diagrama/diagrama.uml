@startuml
class Pessoa {
  String Cpf
  String Nome
}

class Reserva {
  Date Inicio
  Date Fim
}

class Emprestimo {
  Date Inicio
  Date Fim
}

class Chave {
  String Codigo
  Int Numero
}

class ChaveSala {
}

class ChavePredio {
}

class Predio {
  String PredioId
}

class Sala {
  String SalaId
}

Chave <-- ChaveSala
Chave <-- ChavePredio
Predio "1..1" *-- "1..n" Sala
Predio "1..1" *-- "1..n" ChavePredio
Sala "1..1" *-- "1..n" ChaveSala
Chave "1..1" -- "1..n" Reserva
Reserva "1..n" -- "1..1" Pessoa
Pessoa "2..3" -- "1..n" Emprestimo
Emprestimo "1..n" -- "1..1" Chave
@enduml